PORT=3000

# Relative to process.cwd() or absolute path (TypeORM sqljs + sql.js package)
SQLITE_DATABASE=data/app.sqlite

# Schema sync: in development, tables are created/updated unless you set DB_SYNC=false.
# In production (NODE_ENV=production), sync stays off unless DB_SYNC=true.
# If you see "no such table: suppliers", ensure you are not on production with sync off,
# or delete the sqlite file and restart once with sync enabled.
DB_SYNC=
DB_LOGGING=false
